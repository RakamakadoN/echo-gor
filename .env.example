# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: Supabase project API URL for Echo Gor 1.0 MVP database.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"

# SUPABASE_SERVICE_ROLE_KEY: Server-only key used by Express API.
# Never expose this value to the browser.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# ── Парсер афиши (server/danceEventsParser.ts) ──
# CRON_SECRET: защита cron-эндпоинта /api/cron/parse-dance-events (Vercel шлёт его сам).
CRON_SECRET="LONG_RANDOM_STRING"

# Scraping-прокси для обхода Cloudflare/бот-защиты агрегаторов (Ticketon, Kassir).
# Без него серверный fetch с Vercel блокируется (403/JS-заглушка).
# SCRAPER_PROVIDER: scraperapi (по умолчанию) | scrapingbee
SCRAPER_API_KEY="YOUR_SCRAPER_API_KEY"
SCRAPER_PROVIDER="scraperapi"
# SCRAPER_RENDER=true — включить JS-рендеринг (нужно для Kassir; расходует больше кредитов).
SCRAPER_RENDER="false"
# SCRAPER_API_URL: необязательный кастомный шаблон для любого провайдера, токены {url} и {key}.
# SCRAPER_API_URL="https://api.example.com/?key={key}&url={url}"
